rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── helpers ────────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function areLinkedPartners(uid) {
      return isSignedIn()
             && request.auth.uid != uid
             && userDoc(uid).data.partnerId == request.auth.uid
             && userDoc(request.auth.uid).data.partnerId == uid;
    }

    function partnerSharesAnalytics(uid) {
      return areLinkedPartners(uid)
             && (
                  userDoc(uid).data.partnerPreferences.shareAnxietyRemaining == true
                  || userDoc(uid).data.partnerPreferences.shareDailyMood == true
                );
    }

    function partnerSharesJourneyCalendar(uid) {
      return areLinkedPartners(uid)
             && userDoc(uid).data.partnerPreferences.shareJourneyCalendar == true;
    }

    // ── users/{uid} ────────────────────────────────────────────────────────
    // Any signed-in user can read basic profile documents (to load partner names/avatars).
    // Only the owner can write their own profile document.
    match /users/{uid} {
      allow read:   if isSignedIn();
      allow create: if isOwner(uid)
                    && request.resource.data.keys().hasAll(
                         ['name', 'email', 'username', 'createdAt']
                       );
      allow update: if isOwner(uid);
      allow delete: if false; // profiles are never deleted client-side

      // ── users/{uid}/anoReactions/{postId} ────────────────────────────
      // A user may only manage their own reaction documents.
      match /anoReactions/{postId} {
        allow read, delete: if isOwner(uid);
        allow create, update: if isOwner(uid)
                              && request.resource.data.keys().hasOnly(['type'])
                              && request.resource.data.type in ['support', 'relate', 'encouragement'];
      }

      // ── users/{uid}/breathing_sessions ───────────────────────────────
      match /breathing_sessions/{sessionId} {
        allow read:   if isOwner(uid);
        allow create: if isOwner(uid)
                      && request.resource.data.keys().hasAll(
                           ['exerciseType', 'completed', 'durationSeconds',
                            'timestamp']
                         );
        allow update, delete: if false; // sessions are immutable once saved
      }

      // ── users/{uid}/erp_sessions ─────────────────────────────────────
      match /erp_sessions/{sessionId} {
        allow read:   if isOwner(uid);
        allow create: if isOwner(uid)
                      && request.resource.data.keys().hasAll(
                           ['session_complete', 'duration_mins',
                            'pre_anxiety', 'post_anxiety', 'timestamp']
                         );
        allow update, delete: if false;
      }

      // ── users/{uid}/habit_trackers/{habitId} ─────────────────────────
      match /habit_trackers/{habitId} {
        allow read:   if isOwner(uid);
        allow create: if isOwner(uid)
                      && request.resource.data.keys().hasAll(
                           ['name', 'normalizedName', 'markedDates',
                            'createdAt', 'updatedAt']
                         );
        // Only 'markedDates' and 'updatedAt' may change on update.
        allow update: if isOwner(uid)
                      && request.resource.data.diff(resource.data)
                           .affectedKeys()
                           .hasOnly(['markedDates', 'updatedAt']);
        allow delete: if false;
      }

      // ── users/{uid}/user_stats/{statId} ──────────────────────────────
      match /user_stats/{statId} {
        allow read:   if isOwner(uid);
        allow write:  if false; // only Cloud Functions can update gamification stats
      }

      // ── users/{uid}/timeline_events/{eventId} ────────────────────────
      match /timeline_events/{eventId} {
        allow read:   if isOwner(uid) || partnerSharesJourneyCalendar(uid);
        allow write:  if false; // strictly managed by Cloud Functions
      }

      // ── users/{uid}/daily_analytics/{dateKey} ────────────────────────
      match /daily_analytics/{dateKey} {
        allow read:   if isOwner(uid) || partnerSharesAnalytics(uid);
        allow write:  if false; // strictly managed by Cloud Functions
      }

      // ── users/{uid}/cbt_journal ──────────────────────────────────────
      match /cbt_journal/{entryId} {
        allow read:   if isOwner(uid);
        allow create: if isOwner(uid)
                      && request.resource.data.keys().hasAll(
                           ['journalNumber', 'createdAt']
                         );
        allow update, delete: if false;
      }

      // ── users/{uid}/daily_moods/{dateKey} ────────────────────────────
      match /daily_moods/{dateKey} {
        allow read:   if isOwner(uid);
        allow create: if isOwner(uid)
                      && request.resource.data.keys().hasAll(
                           ['score', 'loggedAt']
                         )
                      && request.resource.data.score is int
                      && request.resource.data.score >= 1
                      && request.resource.data.score <= 5;
        // Allow re-logging (set with merge) the same day — same constraints.
        allow update: if isOwner(uid)
                      && request.resource.data.keys().hasAll(
                           ['score', 'loggedAt']
                         )
                      && request.resource.data.score is int
                      && request.resource.data.score >= 1
                      && request.resource.data.score <= 5;
        allow delete: if false;
      }

      // ── users/{uid}/meditation_history/{eventId} ─────────────────────
      match /meditation_history/{eventId} {
        allow read, create, update: if isOwner(uid);
        allow delete: if false;
      }
    }

    // ── usernames/{username} ───────────────────────────────────────────────
    // Anyone signed in may check if a username is taken (read).
    // Only a signed-in user may reserve a username, and only with their uid.
    // No updates or deletes — username reservation is permanent.
    match /usernames/{username} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn()
                    && request.resource.data.keys().hasOnly(['uid'])
                    && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    // ── partner_invites ────────────────────────────────────────────────────
    match /partner_invites/{inviteId} {
      allow read:   if isSignedIn() 
                    && (resource.data.senderId == request.auth.uid 
                        || resource.data.receiverId == request.auth.uid);
      allow create, update, delete: if false; // strictly managed by Cloud Functions
    }

    // ── anoPosts ───────────────────────────────────────────────────────────
    match /anoPosts/{postId} {
      // Any signed-in user can read posts.
      allow read: if isSignedIn();

      // Create: must supply required fields; uid must match the caller.
      allow create: if isSignedIn()
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.keys().hasAll(
                         ['uid', 'authorName', 'content', 'category',
                          'createdAt', 'reactionCounts', 'requiresReview', 'isHidden']
                       )
                    && request.resource.data.content.size() > 0
                    && request.resource.data.content.size() <= 400
                    && request.resource.data.category in [
                         'Struggling Today', 'Small Win', 'ERP Progress',
                         'Seeking Advice', 'Motivation'
                       ];

      // Update: No longer allowed from client. Reactions and moderation are
      // handled by Cloud Functions.
      allow update: if false;

      // Delete: only the original author may delete their post.
      allow delete: if isSignedIn()
                    && resource.data.uid == request.auth.uid;
    }

    // ── meditations ────────────────────────────────────────────────────────
    match /meditations/{meditationId} {
      allow read: if isSignedIn() && resource.data.isActive == true;
      allow write: if false;
    }

    // ── catch-all: deny everything not explicitly covered ──────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
